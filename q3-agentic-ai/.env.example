# Ollama server + model configuration
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b

# Database (SQLAlchemy-style SQLite URL; relative paths resolve to project root)
DATABASE_URL=sqlite:///./analytics.db

# Agent behaviour (optional overrides)
AGENT_MAX_ITERATIONS=12
SQL_ROW_LIMIT=1000
OLLAMA_TIMEOUT=120
