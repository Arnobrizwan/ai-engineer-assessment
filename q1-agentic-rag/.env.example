# Copy to .env and adjust as needed. Never commit your real .env.

# Ollama server (serves native API at this URL and OpenAI-compatible at /v1).
OLLAMA_BASE_URL=http://localhost:11434

# Models (pull beforehand: `ollama pull llama3.1:8b` and `ollama pull nomic-embed-text`).
LLM_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# --- Optional retrieval / agent tuning (sensible defaults shown) ---
CHUNK_SIZE=700
CHUNK_OVERLAP=120
TOP_K=5
RRF_K=60
MAX_AGENT_ITERATIONS=2
